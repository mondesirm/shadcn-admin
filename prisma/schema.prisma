// Prisma schema for tasks
// Save this as schema.prisma in the root or prisma/ directory

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id          String   @id @default(uuid())
  title       String
  status      String
  label       String
  priority    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignee    String
  description String
  dueDate     DateTime
}
